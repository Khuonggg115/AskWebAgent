# === Ask-the-Web Agent - API Keys ===
# Copy file này thành .env và điền API key thật của bạn
# KHÔNG commit file .env lên git!

# Google Gemini API Key
# Lấy tại: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Tavily Search API Key (Phase 2: Web Search)
# Đăng ký miễn phí tại: https://app.tavily.com/sign-in
# Free tier: 1000 searches/tháng
TAVILY_API_KEY=your_tavily_api_key_here
